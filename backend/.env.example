# -------------------------------------------------------------------
# Environment Variables
# Copy this file to `.env` and replace the placeholder values.
# Never commit your actual `.env` file to GitHub.
# -------------------------------------------------------------------

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/your_database

# OpenAI API Key
# Get yours from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# Apify API Token
# Get yours from: https://console.apify.com/account/integrations
APIFY_API_KEY=your_apify_api_token

# Backend server port
PORT=5001

# Drop-off detector window, in minutes. A visitor who reaches a funnel stage but
# not the next stage within this window is reported by GET /api/dropoffs.
# Optional — defaults to 30 if unset.
DROPOFF_WINDOW_MINUTES=30
